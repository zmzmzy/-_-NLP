# LiteLLM local deployment env
LITELLM_PORT=4000
LITELLM_MASTER_KEY=replace_with_strong_master_key

# At least one upstream key is needed
OPENAI_API_KEY=replace_with_openai_key
OPENROUTER_API_KEY=
GEMINI_API_KEY=
SILICONFLOW_API_KEY=
ANTHROPIC_API_KEY=

# Optional persistence for LiteLLM logs
LITELLM_DB_PORT=55432
LITELLM_DB_NAME=litellm
LITELLM_DB_USER=litellm
LITELLM_DB_PASSWORD=litellm_password
# Optional override:
# DATABASE_URL=postgresql://litellm:litellm_password@litellm-postgres:5432/litellm
