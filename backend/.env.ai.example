# AI insight agent environment example

# Optional: override default profile config path
# export GM_AI_AGENT_CONFIG_PATH=/home/roamer/graduation_proj_0.1/backend/config/ai_agent_profiles.json

# -----------------------------
# Primary production chain
# backend -> LiteLLM -> providers
# -----------------------------
export LITELLM_BASE_URL=http://127.0.0.1:4000
export LITELLM_MASTER_KEY=replace_with_litellm_master_key

# -----------------------------
# Optional orchestration layer
# backend -> Dify Workflow -> LiteLLM
# -----------------------------
export DIFY_BASE_URL=http://127.0.0.1:8080
export DIFY_API_KEY=replace_with_dify_app_api_key

# -----------------------------
# Direct provider fallback keys
# -----------------------------
export SILICONFLOW_API_KEY=replace_with_siliconflow_key
export OPENAI_API_KEY=replace_with_openai_key
# export OPENROUTER_API_KEY=replace_with_openrouter_key
# export GEMINI_API_KEY=replace_with_gemini_key

# -----------------------------
# Optional: matching embedding enhancement
# used by algorithm_version = v1.1-hybrid-emb
# -----------------------------
export GM_EMBEDDING_ENABLE=true
export GM_EMBEDDING_BASE_URL=http://127.0.0.1:4000
# export GM_EMBEDDING_ENDPOINT=http://127.0.0.1:4000/v1/embeddings
export GM_EMBEDDING_MODEL=text-embedding-3-small
# API key fallback order:
# GM_EMBEDDING_API_KEY -> LITELLM_MASTER_KEY -> OPENAI_API_KEY
# export GM_EMBEDDING_API_KEY=replace_with_embedding_api_key
export GM_EMBEDDING_TIMEOUT_MS=6000
export GM_EMBEDDING_MAX_TEXT_BYTES=2400
export GM_EMBEDDING_CACHE_SIZE=2000
