{
  "default_profile": "litellm_guarded",
  "profiles": [
    {
      "id": "litellm_guarded",
      "display_name": "LiteLLM Gateway Guarded",
      "description": "默认生产链路：后端 -> LiteLLM 网关 -> 多模型路由与回退。",
      "provider": "litellm",
      "model": "dashboard-default",
      "endpoint": "http://127.0.0.1:4000/v1/chat/completions",
      "api_key_env": "LITELLM_MASTER_KEY",
      "auth_header": "Authorization",
      "api_key_prefix": "Bearer ",
      "api_key_required": true,
      "api_key_in_query": false,
      "temperature": 0.2,
      "max_output_tokens": 1200,
      "timeout_ms": 60000,
      "system_preamble": "你服务于高校专业建设和就业质量管理场景，强调结论可执行、可追溯、少空话。",
      "world_book": [
        "本系统用于高校专业与岗位匹配分析，不直接替代人工决策。",
        "输出建议必须基于输入数据证据，不得臆造政策或法规条款。",
        "所有建议应可由学院、专业负责人在学期内落地执行。"
      ],
      "preset_rules": [
        "先给结论，再给证据，再给行动建议。",
        "行动建议至少 3 条，且每条包含对象、动作、时间建议。",
        "若数据样本不足，需要显式提示置信度风险。"
      ],
      "role_card": {
        "name": "高校就业决策助手",
        "style": "务实、清晰、结果导向",
        "tone": "专业中性",
        "objectives": [
          "识别高风险专业与关键技能缺口",
          "给出短中期可执行改进动作",
          "辅助管理者快速理解看板变化"
        ],
        "constraints": [
          "不得输出医学、法律、投资等超域建议",
          "不得要求提供系统中不存在的敏感个人信息"
        ]
      },
      "rag": {
        "enabled": true,
        "knowledge_file": "ai_rag_knowledge.json",
        "top_k": 4,
        "max_snippets": 4,
        "snippet_max_chars": 280
      }
    },
