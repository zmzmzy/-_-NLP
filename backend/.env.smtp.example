# Copy to backend/.env.smtp and replace values.
# Linux/macOS format for start_linux.sh

GM_SMTP_HOST=smtp.qq.com
GM_SMTP_PORT=465
GM_SMTP_USERNAME=your_account@qq.com
GM_SMTP_PASSWORD=REPLACE_WITH_QQ_SMTP_AUTH_CODE
GM_SMTP_FROM=your_account@qq.com
GM_SMTP_AUTH=LOGIN

GM_SMTP_USE_SSL=true
GM_SMTP_STARTTLS=false
GM_SMTP_SKIP_TLS_VERIFY=false
GM_SMTP_TIMEOUT_MS=10000

GM_PASSWORD_RESET_PAGE_URL=http://127.0.0.1:5173/password
GM_PASSWORD_RESET_DEBUG_RETURN_TOKEN=false
